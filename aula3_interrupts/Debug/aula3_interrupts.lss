void PCINT_config()
{
	PCMSK2 |= (1<<PCINT18)|(1<<PCINT19); //Habilita PCINT18 e PCINT19 (equivale a pinos PD2 e PD3)
	PCICR |= (1<<PCIE2); //Habilita grupo 2 (equivale porta D)
